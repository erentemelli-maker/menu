@using DijitalMenu.Domain
@model AdminStaffViewModel
@{
    ViewData["Title"] = "Personel Yönetimi";
}

<div class="admin-heading mb-4">
    <span class="eyebrow">İŞLETME PANELİ</span>
    <h1>Personel yönetimi</h1>
    <p>Yönetici, garson ve mutfak hesaplarını yönetin. Pasif hesaplar sisteme giriş yapamaz.</p>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-4">
    <div class="col-12 col-lg-4">
        <div class="panel-card">
            <h2 class="h5">@(Model.Staff.Id.HasValue ? "Personeli Düzenle" : "Yeni Personel")</h2>
            <form asp-action="Save" method="post">
                <input asp-for="Staff.Id" type="hidden" />
                <div class="mb-3">
                    <label asp-for="Staff.Username" class="form-label">Kullanıcı adı</label>
                    <input asp-for="Staff.Username" class="form-control" autocomplete="off" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Staff.DisplayName" class="form-label">Görünen ad</label>
                    <input asp-for="Staff.DisplayName" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Staff.Role" class="form-label">Rol</label>
                    <select asp-for="Staff.Role" class="form-select">
                        @foreach (var role in Enum.GetValues<StaffRole>())
                        {
                            <option value="@role">@role.ToTurkish()</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="Staff.Password" class="form-label">
                        @(Model.Staff.Id.HasValue ? "Yeni parola (isteğe bağlı)" : "Parola")
                    </label>
                    <input asp-for="Staff.Password" class="form-control" autocomplete="new-password" />
                </div>
                <div class="form-check mb-3">
                    <input asp-for="Staff.IsActive" class="form-check-input" />
                    <label asp-for="Staff.IsActive" class="form-check-label">Aktif hesap</label>
                </div>
                <button class="btn btn-dark w-100" type="submit">Kaydet</button>
            </form>
        </div>
    </div>
    <div class="col-12 col-lg-8">
        <div class="panel-card">
            @foreach (var user in Model.Users)
            {
                <div class="catalog-line">
                    <div>
                        <strong>@user.DisplayName</strong>
                        <div class="order-meta">@@@user.Username · @user.Role.ToTurkish()</div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge @(user.IsActive ? "text-bg-success" : "text-bg-secondary")">
                            @(user.IsActive ? "Aktif" : "Pasif")
                        </span>
                        <a class="btn btn-sm btn-outline-dark" asp-action="Index" asp-route-editId="@user.Id">Düzenle</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
