@model MenuViewModel
@{
    ViewData["Title"] = "Menü";
}

<div class="hero-card mb-4">
    <span class="eyebrow">Masa @Model.TableNumber · QR Menü</span>
    <h1>İyi yemek,<br />iyi hissettirir.</h1>
    <p class="mb-0">Mutfağımızdan özenle seçilen lezzetleri keşfedin. Siparişiniz birkaç dokunuşla masanıza gelsin.</p>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="table-service-actions mb-4">
    <form asp-controller="TableService" asp-action="Create" method="post">
        <input type="hidden" name="branchId" value="@Model.BranchId" />
        <input type="hidden" name="tableNumber" value="@Model.TableNumber" />
        <input type="hidden" name="type" value="CallWaiter" />
        <button class="btn btn-outline-dark w-100" type="submit">Garson Çağır</button>
    </form>
    <form asp-controller="TableService" asp-action="Create" method="post">
        <input type="hidden" name="branchId" value="@Model.BranchId" />
        <input type="hidden" name="tableNumber" value="@Model.TableNumber" />
        <input type="hidden" name="type" value="RequestBill" />
        <button class="btn btn-dark w-100" type="submit">Hesap İste</button>
    </form>
</div>

<div class="section-toolbar">
    <div>
        <span class="eyebrow">Bugünün Seçkisi</span>
        <h2 class="section-title mt-1">Menüyü keşfedin</h2>
    </div>
    <a class="btn btn-dark" asp-controller="Cart" asp-action="Index" asp-route-branchId="@Model.BranchId" asp-route-tableNumber="@Model.TableNumber">
        Sepetim
    </a>
</div>

@foreach (var category in Model.Categories)
{
    <details class="menu-category mb-3">
        <summary class="category-toggle">
            <span>
                <small>Lezzet kategorisi</small>
                <strong>@category.Name</strong>
            </span>
            <span class="category-count">@category.Products.Count ürün</span>
            <i aria-hidden="true"></i>
        </summary>
        <div class="category-products">
            <div class="row g-3">
                @{ var productIndex = 0; }
                @foreach (var product in category.Products)
                {
                    <div class="col-12 col-md-6 menu-product-entry" style="--delay: @(productIndex * 45)ms">
                        <article class="product-card h-100">
                            <img class="product-image" src="@product.ImageUrl" alt="@product.Name" loading="lazy" />
                            <div class="product-content">
                                <div>
                                    <h4>@product.Name</h4>
                                    <p>@product.Description</p>
                                </div>
                                <div class="d-flex justify-content-between align-items-center gap-2">
                                    <strong class="price">@product.Price.ToString("N2") ₺</strong>
                                    <form asp-action="AddToCart" method="post">
                                        <input type="hidden" name="branchId" value="@Model.BranchId" />
                                        <input type="hidden" name="tableNumber" value="@Model.TableNumber" />
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <button class="btn btn-sm btn-outline-dark" type="submit">+ Sepete Ekle</button>
                                    </form>
                                </div>
                            </div>
                        </article>
                    </div>
                    productIndex++;
                }
            </div>
        </div>
    </details>
}
