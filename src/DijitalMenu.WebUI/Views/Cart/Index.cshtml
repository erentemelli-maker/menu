@model CartViewModel
@{
    ViewData["Title"] = "Sepet";
}

<div class="admin-heading mb-4">
    <div>
        <span class="eyebrow">MASA @Model.TableNumber</span>
        <h1>Sipariş özeti</h1>
        <p>Seçimlerinizi kontrol edin, ekstralarınızı ve mutfak notunuzu ekleyin.</p>
    </div>
    <a class="btn btn-outline-dark" asp-controller="Menu" asp-action="Index" asp-route-branchId="@Model.BranchId" asp-route-tableNumber="@Model.TableNumber">Menüye Dön</a>
</div>

@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

@if (Model.Lines.Count == 0)
{
    <div class="empty-card">Sepetiniz henüz boş. Menüden sevdiğiniz lezzetleri ekleyebilirsiniz.</div>
}
else
{
    <div class="order-card">
        @foreach (var line in Model.Lines)
        {
            <form class="cart-editor" asp-action="Update" method="post">
                <input type="hidden" name="branchId" value="@Model.BranchId" />
                <input type="hidden" name="tableNumber" value="@Model.TableNumber" />
                <input type="hidden" name="productId" value="@line.ProductId" />
                <div class="cart-line">
                    <div>
                        <strong>@line.ProductName</strong>
                        <div class="text-muted">@line.LineTotal.ToString("N2") ₺</div>
                    </div>
                    <label class="cart-quantity">
                        <span>Adet</span>
                        <input class="form-control" type="number" name="quantity" min="1" max="20" value="@line.Quantity" />
                    </label>
                </div>
                @if (line.Extras.Count > 0)
                {
                    <div class="cart-extras">
                        @foreach (var extra in line.Extras)
                        {
                            <label>
                                <input class="form-check-input" type="checkbox" name="extraIds" value="@extra.Id" checked="@extra.IsSelected" />
                                <span>@extra.Name <small>+@extra.Price.ToString("N2") ₺</small></span>
                            </label>
                        }
                    </div>
                }
                <textarea class="form-control" name="note" rows="2" maxlength="240" placeholder="Mutfak notu: soğansız, az pişmiş, buzsuz...">@line.Note</textarea>
                <div class="d-flex justify-content-between gap-2 mt-2">
                    <button class="btn btn-sm btn-outline-dark" type="submit">Seçimleri Güncelle</button>
                    <button class="btn btn-sm btn-link text-danger" type="submit" formaction="@Url.Action("Remove")">Kaldır</button>
                </div>
            </form>
        }
        <div class="cart-total">
            <span>Toplam</span>
            <strong>@Model.Total.ToString("N2") ₺</strong>
        </div>
        <form asp-action="Checkout" method="post">
            <input type="hidden" name="branchId" value="@Model.BranchId" />
            <input type="hidden" name="tableNumber" value="@Model.TableNumber" />
            <button class="btn btn-dark w-100 py-3" type="submit">Siparişi Mutfağa İlet</button>
        </form>
    </div>
}
