@model AdminCatalogViewModel
@{
    ViewData["Title"] = "Katalog Yönetimi";
}

<div class="admin-heading mb-4">
    <span class="eyebrow">İŞLETME PANELİ</span>
    <h1>Katalog yönetimi</h1>
    <p>Menünüzün vitrinini yönetin. Kategorileri sıralayın, ürünleri güncel tutun.</p>
</div>

@if (TempData["Message"] is string message)
{
    <div class="alert alert-success">@message</div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger">@error</div>
}

<div class="row g-4">
    <div class="col-12 col-lg-4">
        <div class="panel-card">
            <h2 class="h5">@(Model.Category.Id.HasValue ? "Kategori Düzenle" : "Yeni Kategori")</h2>
            <form asp-action="SaveCategory" method="post">
                <input asp-for="Category.Id" type="hidden" />
                <div class="mb-3">
                    <label asp-for="Category.Name" class="form-label">Kategori Adı</label>
                    <input asp-for="Category.Name" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label asp-for="Category.DisplayOrder" class="form-label">Sıra</label>
                    <input asp-for="Category.DisplayOrder" class="form-control" min="0" />
                </div>
                <button class="btn btn-dark w-100" type="submit">Kaydet</button>
            </form>
        </div>
    </div>
    <div class="col-12 col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">Kategoriler</h2>
            <a class="btn btn-dark" asp-action="EditProduct">Yeni Ürün</a>
        </div>
        @foreach (var category in Model.Categories)
        {
            <div class="panel-card mb-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <div>
                        <strong>@category.Name</strong>
                        <span class="text-muted ms-2">Sıra: @category.DisplayOrder</span>
                    </div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-dark" asp-action="Index" asp-route-editCategoryId="@category.Id">Düzenle</a>
                        <form asp-action="DeleteCategory" method="post">
                            <input type="hidden" name="id" value="@category.Id" />
                            <button class="btn btn-sm btn-outline-danger" type="submit">Sil</button>
                        </form>
                    </div>
                </div>
                @foreach (var product in Model.Products.Where(product => product.CategoryId == category.Id))
                {
                    <div class="catalog-line">
                        <div>
                            <strong>@product.Name</strong>
                            <span class="text-muted ms-2">@product.Price.ToString("N2") ₺</span>
                            @if (!product.IsAvailable)
                            {
                                <span class="badge text-bg-secondary ms-2">Pasif</span>
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-sm btn-link" asp-action="EditProduct" asp-route-id="@product.Id">Düzenle</a>
                            <form asp-action="DeleteProduct" method="post">
                                <input type="hidden" name="id" value="@product.Id" />
                                <button class="btn btn-sm btn-link text-danger" type="submit">Sil</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
