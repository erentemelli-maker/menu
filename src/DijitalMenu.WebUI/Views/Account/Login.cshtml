@model LoginViewModel
@{
    ViewData["Title"] = "İşletme Girişi";
}

<div class="login-wrap">
    <section class="login-card">
        <span class="eyebrow">Restaurant OS</span>
        <h1>Tekrar hoş geldiniz.</h1>
        <p>Siparişleri, mutfağı ve servis akışını yönetmek için giriş yapın.</p>

        <form asp-action="Login" method="post">
            <input asp-for="ReturnUrl" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <div class="mb-3">
                <label asp-for="Username" class="form-label">Kullanıcı adı</label>
                <input asp-for="Username" class="form-control" autocomplete="username" />
            </div>
            <div class="mb-4">
                <label asp-for="Password" class="form-label">Şifre</label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
            </div>
            <button class="btn btn-dark w-100 py-3" type="submit">Panele Giriş Yap</button>
        </form>

        <div class="demo-users">
            <strong>Demo hesapları</strong>
            <span><code>admin / admin123</code></span>
            <span><code>garson / garson123</code></span>
            <span><code>mutfak / mutfak123</code></span>
        </div>
    </section>
</div>
